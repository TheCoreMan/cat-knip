{
  "name": "cat-knip",
  "version": "0.1.0",
  "description": "Find unused NestJS module exports from the runtime dependency graph.",
  "keywords": [
    "nestjs",
    "dependency-injection",
    "lint",
    "testing",
    "unused-exports"
  ],
  "homepage": "https://github.com/TheCoreMan/cat-knip#readme",
  "bugs": "https://github.com/TheCoreMan/cat-knip/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheCoreMan/cat-knip.git"
  },
  "license": "MIT",
  "author": "Shay Nehmad",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "testing": [
        "./dist/testing.d.ts"
      ],
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf coverage dist",
    "ci": "pnpm run format:check && pnpm run lint && pnpm run test:cov && pnpm run build && pnpm run pack:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm run lint:eslint && pnpm run lint:check-types && pnpm run lint:unused",
    "lint:check-types": "tsc --noEmit",
    "lint:eslint": "eslint .",
    "lint:unused": "knip",
    "pack:check": "publint && attw --pack . --profile node16",
    "prepack": "pnpm run clean && pnpm run build",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=11.8.0"
  },
  "packageManager": "pnpm@11.8.0",
  "peerDependencies": {
    "@nestjs/common": ">=10 <12",
    "@nestjs/core": ">=10 <12",
    "@nestjs/testing": ">=10 <12"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.9",
    "@nestjs/testing": "^11.1.9",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.14",
    "@typescript/native": "npm:typescript@7.0.2",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^50.6.3",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "knip": "^5.62.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.1.0",
    "publint": "^0.3.15",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.4.5",
    "typescript": "npm:@typescript/typescript6@6.0.2"
  },
  "lint-staged": {
    "*.{js,mjs,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": "prettier --write"
  }
}
